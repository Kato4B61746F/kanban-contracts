; Routes the @kato4b61746f scope to GitHub Packages.
@kato4b61746f:registry=https://npm.pkg.github.com

; Auth for GitHub Packages. NODE_AUTH_TOKEN is set in CI by actions/setup-node;
; locally this is unset and the resulting "Failed to replace env in config" warning
; from pnpm is benign (publish only happens in CI).
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
